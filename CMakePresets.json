{
    "version": 6,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/_build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "default",
            "inherits": "base"
        },
        {
            "name": "dev",
            "inherits": "base",
            "cacheVariables": {
                "FFDAS_BUILD_PYTHON": "ON",
                "FFDAS_BUILD_MATLAB": "ON",
                "FFDAS_DEVELOPMENT_BUILD": "ON"
            }
        },
        {
            "name": "dev-python",
            "inherits": "base",
            "cacheVariables": {
                "FFDAS_BUILD_PYTHON": "ON",
                "FFDAS_DEVELOPMENT_BUILD": "ON"
            }
        },
        {
            "name": "dev-matlab",
            "inherits": "base",
            "cacheVariables": {
                "FFDAS_BUILD_MATLAB": "ON",
                "FFDAS_DEVELOPMENT_BUILD": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default",
            "configuration": "Release"
        },
        {
            "name": "dev",
            "configurePreset": "dev",
            "configuration": "Release"
        },
        {
            "name": "dev-python",
            "configurePreset": "dev-python",
            "configuration": "Release"
        },
        {
            "name": "dev-matlab",
            "configurePreset": "dev-matlab",
            "configuration": "Release"
        }
    ]
}
