{
    "version": 6,
    "configurePresets": [
        {
            "name": "default",
            "binaryDir": "${sourceDir}/_build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "dev",
            "binaryDir": "${sourceDir}/_build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "FFDAS_BUILD_PYTHON": "ON",
                "FFDAS_BUILD_MATLAB": "ON",
                "FFDAS_DEVELOPMENT_BUILD": "ON"
            }
        },
        {
            "name": "dev-python",
            "binaryDir": "${sourceDir}/_build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "FFDAS_BUILD_PYTHON": "ON",
                "FFDAS_DEVELOPMENT_BUILD": "ON"
            }
        },
        {
            "name": "dev-matlab",
            "binaryDir": "${sourceDir}/_build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "FFDAS_BUILD_MATLAB": "ON",
                "FFDAS_DEVELOPMENT_BUILD": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "dev",
            "configurePreset": "dev"
        },
        {
            "name": "dev-python",
            "configurePreset": "dev-python"
        },
        {
            "name": "dev-matlab",
            "configurePreset": "dev-matlab"
        }
    ]
}
